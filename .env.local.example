# SoSoValue API — request from https://sosovalue.gitbook.io/soso-value-api-doc/
SOSOVALUE_API_KEY=

# SoDEX API — testnet first, then mainnet (mainnet requires deposit)
# Testnet base: https://api-testnet.sodex.com
# Mainnet base: https://api.sodex.com
SODEX_API_KEY=
SODEX_API_SECRET=
# Network — "testnet" (default, safe) or "mainnet" (requires deposit + whitelist).
# The SoDEX client picks the right base URL automatically. SODEX_BASE_URL
# below overrides this if set.
MOSAIC_NETWORK=testnet
SODEX_BASE_URL=
# Exposed to the browser so the navbar can show the network badge.
NEXT_PUBLIC_MOSAIC_NETWORK=testnet

# Anthropic key for the thesis-interpretation agent (optional — falls back to deterministic mock)
ANTHROPIC_API_KEY=

# Set to "true" to force the in-memory mock data layer (useful for offline demos)
MOSAIC_USE_MOCKS=false
