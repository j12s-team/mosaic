# SoSoValue API — request from https://sosovalue.gitbook.io/soso-value-api-doc/
SOSOVALUE_API_KEY=

# SoDEX API — testnet first, then mainnet (mainnet requires deposit)
# Spot REST gateway:
#   Testnet: https://testnet-gw.sodex.dev/api/v1/spot
#   Mainnet: https://mainnet-gw.sodex.dev/api/v1/spot
SODEX_API_KEY=
SODEX_API_SECRET=
# Network — "testnet" (default, safe) or "mainnet" (requires deposit + whitelist).
# The SoDEX client picks the right base URL automatically. SODEX_BASE_URL
# below overrides this if set.
MOSAIC_NETWORK=testnet
# Override to pin a specific gateway. Leave empty to use the network default.
# SODEX_BASE_URL=https://testnet-gw.sodex.dev/api/v1/spot
SODEX_BASE_URL=
# Exposed to the browser so the navbar can show the network badge.
NEXT_PUBLIC_MOSAIC_NETWORK=testnet
# Mainnet safety gate — orders are refused unless this is "yes".
# MOSAIC_ALLOW_MAINNET_ORDERS=no

# Anthropic key for the thesis-interpretation agent (optional — falls back to deterministic mock)
ANTHROPIC_API_KEY=

# Set to "true" to force the in-memory mock data layer (useful for offline demos)
MOSAIC_USE_MOCKS=false

# Set to "1" to log every SoDEX request URL + parsed balance rows to the server
# logs. Handy when debugging "why is my wallet showing $0" — turn on, hit
# /api/portfolio?address=0x..., and check the Vercel function logs.
MOSAIC_DEBUG_SODEX=0
