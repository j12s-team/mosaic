# ============================================================================
# Mosaic environment template
# Copy to .env.local, fill in keys, and flip flags as you go live:
#   cp .env.local.example .env.local
# Everything is optional — with no keys the app runs on deterministic mocks.
# ============================================================================

# --- SoSoValue (market data: prices, news, ETF flows, SSI indices) ---------
# Request a key: https://sosovalue.gitbook.io/soso-value-api-doc
# With no key, market surfaces show labeled demo data.
SOSOVALUE_API_KEY=

# --- SoDEX (execution venue) ------------------------------------------------
# X-API-Key is the API key NAME registered with SoDEX.
# The SECRET is the EVM PRIVATE KEY registered with that API key — SoDEX
# authenticates orders with an EIP-712 wallet signature, not an HMAC.
# NEVER commit this or paste it anywhere.
SODEX_API_KEY=
SODEX_API_SECRET=
# Optional account id if your SoDEX account has one.
SODEX_ACCOUNT_ID=

# Network: "testnet" (default, safe) or "mainnet". Picks the right gateway
# (testnet-gw.sodex.dev / mainnet-gw.sodex.dev) automatically.
# Do NOT set SODEX_BASE_URL unless SoDEX gives you a custom gateway — a wrong
# override silently breaks every SoDEX call.
MOSAIC_NETWORK=testnet
# Same value, exposed to the browser (navbar badge + mandate requirement UI).
NEXT_PUBLIC_MOSAIC_NETWORK=testnet
# SODEX_BASE_URL=

# --- Mainnet safety rails (all must be deliberately flipped) ----------------
# Master switch: mainnet orders are refused unless this is exactly "true".
MOSAIC_MAINNET_ENABLED=false
# DEPRECATED (simulated-as-real fix): MOSAIC_REAL_ORDERS no longer gates
# anything. Trading is LIVE whenever SODEX_API_KEY/SECRET are set and mocks
# are off; without credentials the app runs in clearly-labeled DEMO mode.
# MOSAIC_DRY_RUN=1 remains the explicit safety valve for first armed runs.
# MOSAIC_REAL_ORDERS=
# Build + sign orders but do NOT send them; logs the would-be request.
# Keep =1 for the first armed run on each network, then remove.
MOSAIC_DRY_RUN=1
# Server-wide per-plan notional cap (USD) on mainnet, independent of any
# mandate. Second line of defense.
MOSAIC_GLOBAL_MAX_NOTIONAL=100
# Emergency stop: =1 blocks ALL mandate-gated execution regardless of the
# in-app kill switch state.
# MOSAIC_KILL_SWITCH=1

# --- Durable track records (Neon / Vercel Postgres) -------------------------
# When set, baskets + snapshots persist server-side, the daily cron
# snapshotter runs, and public basket pages + mandates become available.
DATABASE_URL=
# Vercel Cron auth: Vercel sends "Authorization: Bearer $CRON_SECRET"
# automatically. Generate: openssl rand -hex 32
CRON_SECRET=
# HMAC key signing each hash-chained snapshot (tamper-evident records).
# Treat as permanent once the first snapshot is written.
# Generate: openssl rand -hex 32
SNAPSHOT_SIGNING_KEY=

# --- Sessions & internal pages (Phase 5a / Phase 2) -------------------------
# HMAC secret for server-verified SIWE sessions. REQUIRED in any deployment
# that persists wallet-owned data; without it, sessions degrade to the legacy
# client-asserted demo behavior. Generate: openssl rand -hex 32
SESSION_SECRET=
# Token gating the internal /status page (+ /api/diag) in production.
STATUS_TOKEN=

# --- Fees (Phase 5b groundwork — leave 0/unset until spike + legal clear) ----
# Basis points charged per executed plan, recorded in audit trail + response.
# 0/unset = disabled. Hard ceiling 100 bps.
MOSAIC_FEE_BPS=

# --- Analytics (Phase 4, optional) -------------------------------------------
# PostHog project key; nothing loads without it.
NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Base URL for "verify on SoDEX" order links in the execution receipt.
# NEXT_PUBLIC_SODEX_EXPLORER_URL=https://testnet.sodex.dev

# --- Optional ----------------------------------------------------------------
# Claude (Haiku) for thesis interpretation; keyword classifier fallback if unset.
ANTHROPIC_API_KEY=
# Force the in-memory mock layer even when keys are present ("true"/"false").
MOSAIC_USE_MOCKS=false
# Log every SoDEX/SoSoValue request URL for debugging ("1" to enable).
MOSAIC_DEBUG_SODEX=
