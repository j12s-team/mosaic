# ============================================================================
# Mosaic — environment template (COMMITTABLE; contains NO real values)
#
# Monorepo: each app loads env from ITS OWN directory, not this root file.
#   • apps/app/.env.local        — local dev for the platform
#   • apps/site/.env.local       — local dev for the marketing site
#   • apps/*/.env.production.local — local PRODUCTION builds (gitignored)
#
# Vercel deployments do NOT read any committed file. Set these in each
# Vercel project's Settings → Environment Variables (scope: Production).
# See DEPLOY.md and scripts/vercel-env-push.sh.
# ============================================================================

# ─────────────────────────── apps/app (platform) ───────────────────────────

# Market data (SoSoValue)
SOSOVALUE_API_KEY=

# SoDEX trading key — DISTINCT from the SoSoValue key, and NETWORK-SCOPED.
# Create it in the SoDEX app (Trade → API keys) under your whitelisted wallet
# ON THE NETWORK YOU TRADE. SODEX_API_KEY is the key NAME; SODEX_API_SECRET is
# the EVM private key registered with it (orders are EIP-712 signed).
SODEX_API_KEY=
SODEX_API_SECRET=
SODEX_ACCOUNT_ID=

# Network: testnet | mainnet. Picks the SoDEX gateway automatically.
MOSAIC_NETWORK=testnet
NEXT_PUBLIC_MOSAIC_NETWORK=testnet
# SODEX_BASE_URL=            # only if SoDEX gives you a custom gateway

# Mainnet safety rails (all deliberate)
MOSAIC_MAINNET_ENABLED=false   # must be exactly "true" to allow mainnet orders
MOSAIC_DRY_RUN=1               # 1 = build+sign but DON'T send (first armed run)
MOSAIC_GLOBAL_MAX_NOTIONAL=100 # server-wide per-plan USD cap
# MOSAIC_KILL_SWITCH=1         # blocks ALL mandate-gated execution
MOSAIC_USE_MOCKS=false         # true = force demo/mock layer
MOSAIC_DEBUG_SODEX=            # 1 = log every SoDEX request

# Sessions (5a) — REQUIRED in any deploy that persists wallet-owned data
SESSION_SECRET=               # openssl rand -hex 32
STATUS_TOKEN=                 # gates /status + /api/diag in production

# Fees (5b groundwork) — 0/unset = disabled
MOSAIC_FEE_BPS=

# Durable track records (Neon / Vercel Postgres)
DATABASE_URL=
CRON_SECRET=                  # openssl rand -hex 32
SNAPSHOT_SIGNING_KEY=         # openssl rand -hex 32 — permanent once written

# Optional
ANTHROPIC_API_KEY=
NEXT_PUBLIC_SODEX_EXPLORER_URL=wss://mainnet-gw.sodex.dev/ws/spot

# ──────────────────────────── apps/site (landing) ──────────────────────────
SOSOVALUE_API_KEY=
NEXT_PUBLIC_MOSAIC_NETWORK=mainnet
NEXT_PUBLIC_APP_URL=          # https://app.mosaic.xyz — where "Launch App" points
NEXT_PUBLIC_SITE_URL=        # https://mosaic.xyz — for OG/metadata base

# ──────────────────────── shared analytics (both apps) ─────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
